            "coding": [
              {
                "system": "urn:virpat:fhir:doc-type",
                "code": "patient-history"
              }
            ]
          }
        ],
        "subject": {
          "reference": "urn:uuid:11111111-1111-4111-8111-111111111111"
        },
        "payload": [
          {
            "contentString": "{patientName} has no prior hospitalizations. She has no known history of peptic ulcer disease, oesophagitis, or Barrett's oesophagus. She does not have diabetes, asthma, or cardiovascular disease. She has been taking ibuprofen occasionally for tension headaches, which may contribute to gastric irritation and worsening of reflux symptoms [MEDDIALOG:K21.9:0]. She has never smoked. Alcohol intake is moderate (approximately 5–8 units per week). She drinks 2–3 cups of coffee daily and regularly consumes spicy and acidic foods [MEDDIALOG:K21.9:0]. She reports no previous formal investigations for her gastrointestinal complaints. No prior endoscopy has been performed until this assessment. She has no history of abdominal surgery. Family history is notable for gastro-oesophageal reflux disease in her mother and peptic ulcer disease in her father. {patientName} is not currently pregnant and takes no hormonal contraception. Her BMI is within the normal range. She denies alarm symptoms including pain on swallowing, dysphagia, weight loss, or anaemia [PMID:9861914]."
          }
        ]
      }
    }
