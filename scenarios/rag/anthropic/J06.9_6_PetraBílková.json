        },
        "category": [
          {
            "coding": [
              {
                "system": "urn:virpat:fhir:doc-type",
                "code": "patient-history"
              }
            ]
          }
        ],
        "subject": {
          "reference": "urn:uuid:11111111-1111-4111-8111-111111111111"
        },
        "payload": [
          {
            "contentString": "{patientName} has no known chronic conditions or significant prior hospitalizations. She was born at term via normal vaginal delivery and has met all developmental milestones. She is fully vaccinated according to the Czech national immunization schedule. {patientName} attends an after-school daycare group, and her mother notes that she frequently gets colds, especially during winter months, which is consistent with the high rate of viral URIs in children attending group care settings [MEDDIALOG:J06.9:0]. She had one episode of otitis media at age 4, which was treated with antibiotics without complications. There is a family history of seasonal allergic rhinitis in her father, which is relevant as allergic predisposition may contribute to recurrent upper respiratory symptoms [MEDDIALOG:J06.9:0]. {patientName} has no known drug allergies other than a mild urticarial reaction to amoxicillin. She is not on any regular medications. No passive tobacco smoke exposure; no recent travel abroad."
          }
        ]
      }
    }
