    {
      "fullUrl": "urn:uuid:ac13f0eb-f792-4c0e-bc5c-0ff622298e26",
      "resource": {
        "resourceType": "Communication",
        "status": "completed",
        "text": {
          "status": "generated",
          "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\">patient-description</div>"
        },
        "category": [
