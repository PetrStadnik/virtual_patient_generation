              {
                "system": "urn:virpat:fhir:doc-type",
                "code": "patient-history"
              }
            ]
          }
        ],
        "subject": {
          "reference": "urn:uuid:11111111-1111-4111-8111-111111111111"
        },
        "payload": [
          {
            "contentString": "{patientName} has no known chronic medical conditions and no prior hospitalizations, based on parent report. He is generally well and fully active for his age. The current illness began acutely with loose stools consistent with diarrhea [SNOMED:A09.0]. There is no known previous history of inflammatory bowel disease or chronic gastrointestinal complaints. Immunizations are reported as up to date by the parent.\n\nHe attends school regularly and had been well until this episode. There is no recent surgery and no significant medication use before presentation. His parent denies recent serious illness but is concerned because the frequency of diarrhea has made him less active and less interested in food [SNOMED:A09.0]. Family members have been encouraging fluids at home. No bloody stool has been observed so far, although hemorrhagic diarrhea is a recognized possible feature of infectious gastroenteritis and colitis [SNOMED:A09.0]."
          }
        ]
      }
    }
