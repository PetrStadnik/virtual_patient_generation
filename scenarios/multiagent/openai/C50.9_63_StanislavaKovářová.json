    {
      "fullUrl": "urn:uuid:7563d318-edee-4bd5-9d91-319106c9e187",
      "resource": {
        "resourceType": "Communication",
        "status": "completed",
        "text": {
          "status": "generated",
          "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\">patient-description</div>"
