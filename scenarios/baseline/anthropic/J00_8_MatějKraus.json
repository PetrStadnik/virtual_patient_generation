    {
      "fullUrl": "urn:uuid:63922a4c-3584-4141-9829-0727bdb37320",
      "resource": {
        "resourceType": "Communication",
        "status": "completed",
        "text": {
          "status": "generated",
          "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\">patient-description</div>"
