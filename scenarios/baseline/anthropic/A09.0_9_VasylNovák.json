    {
      "fullUrl": "urn:uuid:4e744436-9783-4289-ba5b-8dcafc70ad69",
      "resource": {
        "resourceType": "Communication",
        "status": "completed",
        "text": {
          "status": "generated",
          "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\">patient-description</div>"
