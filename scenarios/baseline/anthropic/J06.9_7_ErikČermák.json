    {
      "fullUrl": "urn:uuid:677b3a11-0f15-45d4-b160-091f04497003",
      "resource": {
        "resourceType": "Communication",
        "status": "completed",
        "text": {
          "status": "generated",
          "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\">patient-description</div>"
        },
        "category": [
