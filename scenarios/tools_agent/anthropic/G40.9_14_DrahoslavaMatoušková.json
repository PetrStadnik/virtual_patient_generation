        "category": [
          {
            "coding": [
              {
                "system": "urn:virpat:fhir:doc-type",
                "code": "patient-history"
              }
            ]
          }
        ],
        "subject": {
          "reference": "urn:uuid:11111111-1111-4111-8111-111111111111"
        },
        "payload": [
          {
            "contentString": "{patientName} has no prior significant medical history aside from the current epilepsy diagnosis, which was established 18 months ago. She was born at term via uncomplicated vaginal delivery, met all developmental milestones on time, and has had no prior hospitalizations except for an overnight stay following her first witnessed tonic-clonic seizure, during which initial investigations were performed. She has no history of head trauma, CNS infections, or neurodevelopmental disorders. There is a family history of epilepsy on the paternal side (father's brother). She is up to date on all recommended vaccinations. She has a documented penicillin allergy (rash). {patientName} is not sexually active and is not on any hormonal contraceptive. Her BMI is within the normal range for her age and sex. She was started on levetiracetam after her first tonic-clonic seizure, and valproic acid was later added due to incomplete seizure control. Lamotrigine was considered but not yet initiated. She is followed every three months in the pediatric neurology outpatient clinic."
          }
        ]
      }
    }
