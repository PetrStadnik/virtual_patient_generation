            "coding": [
              {
                "system": "urn:virpat:fhir:doc-type",
                "code": "patient-history"
              }
            ]
          }
        ],
        "subject": {
          "reference": "urn:uuid:11111111-1111-4111-8111-111111111111"
        },
        "payload": [
          {
            "contentString": "{patientName} has no significant past medical history. She was born at term via normal vaginal delivery with no neonatal complications. She has had two prior episodes of upper respiratory tract infections in the past year, both resolving without complications. She was seen in the emergency department once at age 3 for a febrile seizure, with no recurrence since. She has no known chronic illnesses, no prior surgeries, and no hospitalizations other than the febrile seizure visit. Her growth and developmental milestones are appropriate for her age. She is not currently on any regular medications. Her immunization record is complete. There is no history of asthma, eczema, or recurrent ear infections. Family history is notable for allergic rhinitis in her mother and a history of coronary artery disease in her maternal grandfather."
          }
        ]
      }
    }
